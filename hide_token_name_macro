const tokens = canvas.tokens.controlled;
if (tokens.length > 0) {
  const updates = [];
  tokens.forEach(token => {
    updates.push({
      _id: token.id,
      name: "monster"
    });
  });
  canvas.scene.updateEmbeddedDocuments("Token", updates);
} else {
  ui.notifications.warn("No tokens were selected");
}
